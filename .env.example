# mcp-oauth-gateway configuration (SPEC.md §3) — copy to .env and edit.
# Placeholders only, no real values (GR-5). Every option is an env var with
# a CLI-flag twin; malformed values abort startup (fail-fast).
#
# ── Docker Compose pitfall ────────────────────────────────────────────────
# Compose interpolates `$` inside env_file values. A bcrypt hash like
# "$2b$12$..." MUST have every `$` escaped as `$$` ("$$2b$$12$$..."), or
# the value is silently mangled. Verify inside the container: the hash must
# be 60 characters. (Not needed when exporting the variable from a shell.)
# ──────────────────────────────────────────────────────────────────────────

# ═══ Required ═════════════════════════════════════════════════════════════

# Public base URL = OAuth issuer. Absolute, no path/query/fragment.
# "https://..." even when a reverse proxy terminates TLS in front of the
# gateway. An http URL on a non-loopback host logs a startup WARNING.
EXTERNAL_URL=https://mcp.example.com

# Operator login (self-contained). Prefer PASSWORD_HASH (bcrypt, cost
# 10-12) over plain PASSWORD. Generate without shell history:
#   htpasswd -nBC 12 "" | tr -d ':\n'
# or ./setup.sh. Remember the $ -> $$ escaping (see pitfall above).
PASSWORD_HASH=$$2b$$12$$replace-with-your-bcrypt-hash
#PASSWORD=

# ═══ Install mode A: behind your own TLS-terminating reverse proxy ════════

# Required in mode A: with an https EXTERNAL_URL the gateway would
# otherwise auto-enable ACME and refuse to start behind a proxy.
NO_AUTO_TLS=true

# IPs/CIDRs allowed to set X-Forwarded-* (your reverse proxy). Bare IPs
# and CIDR ranges both work; empty = no proxy trusted.
TRUSTED_PROXIES=203.0.113.10

# ═══ Install mode B: standalone with built-in ACME (no reverse proxy) ═════
# Comment out NO_AUTO_TLS/TRUSTED_PROXIES above, then set:

#TLS_HOST=mcp.example.com     # certificate hostname (Let's Encrypt)
#TLS_ACCEPT_TOS=true          # accept the ACME terms of service
#TLS_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
# Or bring your own certificate instead of ACME (mutually exclusive
# with TLS_HOST):
#TLS_CERT_FILE=/path/to/fullchain.pem
#TLS_KEY_FILE=/path/to/privkey.pem

# ═══ Listeners & storage ══════════════════════════════════════════════════

# Container image defaults: LISTEN=:8080, TLS_LISTEN=:8443 (a non-root
# container cannot bind :80/:443 — publish host ports onto these instead,
# e.g. "443:8443"). Binary defaults outside the image: :80 / :443.
#LISTEN=:8080
#TLS_LISTEN=:8443

# Data directory (signing keys, token store) — the compose volume. The
# signing keys and the HMAC secret are generated here on first start;
# nothing to configure. Back it up (SPEC §2.2).
#DATA_PATH=/data

# Storage backend: local (embedded bbolt, default) or sqlite (+ DSN).
#REPOSITORY_BACKEND=local
#REPOSITORY_DSN=

# ═══ Upstream (the MCP server being fronted) ══════════════════════════════
# The upstream URL itself is the container command (compose `command:`),
# not an env var.

# Bearer token injected toward the upstream; the client never sees it.
# Omit when the upstream is unauthenticated.
PROXY_BEARER_TOKEN=replace-with-upstream-token-or-remove

# Static extra headers toward the upstream ("H1:V1,H2:V2").
#PROXY_HEADERS=

# Forward the validated client bearer to the upstream (default false).
#PROXY_FORWARD_AUTHORIZATION=false

# Reject GET-SSE with 405; streamable-HTTP only (default false).
#HTTP_STREAMING_ONLY=false

# Claim→header mapping toward the upstream (SPEC §1.11.5).
#HEADER_MAPPING=
#HEADER_MAPPING_BASE=/userinfo

# ═══ Token & client lifetimes (defaults shown; SPEC §3.2) ═════════════════

#ACCESS_TOKEN_TTL=1h          # 1m-24h
#AUTH_CODE_TTL=10m            # 30s-1h
#REFRESH_TOKEN_TTL=720h       # 1h-8760h; 0 disables the refresh grant
#CLOCK_SKEW=30s               # 0-5m token-validation leeway

# Client identification: CIMD (primary) + DCR (deprecated fallback).
#CIMD_ENABLED=true
#CIMD_FETCH_TIMEOUT=5s        # 1s-1m
#CIMD_MAX_SIZE=65536          # bytes, 1KiB-1MiB
#CIMD_CACHE_TTL=1h            # 1m-24h
#DCR_ENABLED=true
#DCR_CLIENT_TTL=720h          # 0 disables expiry
#DCR_MAX_CLIENTS=100          # 0 = unlimited (not recommended)

# ═══ Signing keys (SPEC §2.2/§2.3) ════════════════════════════════════════

#KEY_ALG=RS256                # RS256 or ES256; switching triggers a rotation
#KEY_ROTATION_INTERVAL=2160h  # >=1h; 0 disables automatic rotation
# Advanced: a fixed external signing key (PEM) disables the managed key
# directory and rotation entirely. Leave unset.
#JWT_PRIVATE_KEY=

# Session/HMAC secret (base64). Auto-generated into DATA_PATH on first
# start — only set to pin it explicitly (e.g. multi-instance).
#AUTH_HMAC_SECRET=

# ═══ Abuse protection (defaults shown; SPEC §3.2) ═════════════════════════

#RATE_LIMIT_REGISTER=10/m     # per-IP, format N/s|m|h; 0 disables
#RATE_LIMIT_TOKEN=60/m
#RATE_LIMIT_LOGIN=10/m
#RATE_LIMIT_AUTHORIZE=60/m
#LOGIN_LOCKOUT_THRESHOLD=10   # consecutive failures; 0 disables
#LOGIN_LOCKOUT_DURATION=15m   # 1m-24h

# ═══ Optional OIDC login backend (off unless URL+ID+secret are all set) ═══

#OIDC_CONFIGURATION_URL=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_SCOPES=openid,profile,email
#OIDC_USER_ID_FIELD=/email
#OIDC_PROVIDER_NAME=OIDC
#OIDC_ALLOWED_USERS=
#OIDC_ALLOWED_USERS_GLOB=
#OIDC_ALLOWED_ATTRIBUTES=
#OIDC_ALLOWED_ATTRIBUTES_GLOB=
#NO_PROVIDER_AUTO_SELECT=false

# ═══ Discovery extras ═════════════════════════════════════════════════════

# Additionally serve the AS metadata as /.well-known/openid-configuration.
#OIDC_DISCOVERY_MIRROR=false
